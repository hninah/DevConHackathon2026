# Full POST URL (use for AWS Lambda Function URL — no /tutor suffix).
VITE_TUTOR_API_URL=

# Base URL; combined with /tutor when VITE_TUTOR_API_URL is unset (API Gateway style).
VITE_API_BASE_URL=

# Optional full URL for mock exam creation endpoint.
# If unset, frontend uses VITE_API_BASE_URL + /mock-exams/create.
# For Lambda Function URL-only setup, this can be the same as VITE_TUTOR_API_URL.
VITE_MOCK_EXAM_API_URL=

# Set to 1 to use local mock data without a backend.
# VITE_USE_MOCK=0
