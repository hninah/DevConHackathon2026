# Copy this file to .env and fill in values
CLAUDE_MODEL_ID=us.anthropic.claude-sonnet-4-6
TITAN_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0
NOVA_CANVAS_MODEL_ID=amazon.nova-canvas-v1:0
# Region for Nova Canvas TEXT_IMAGE. Not the same as AWS_REGION: Claude/Titan often use
# us-west-2, but Nova Canvas image gen is supported in us-east-1 (enable model in console).
NOVA_CANVAS_REGION=us-east-1
AWS_REGION=us-west-2
MANUAL_PDF_PATH=data/manual.pdf
CHUNKS_OUTPUT_PATH=data/chunks.json

# Runtime PNG scene image: default Stable Diffusion 3.5 (stability); set to nova for Nova Canvas.
# Nova Canvas is Legacy on Bedrock — use stability if you see Legacy / 30-day inactivity errors.
SCENE_IMAGE_PROVIDER=stability
STABILITY_SD35_MODEL_ID=stability.sd3-5-large-v1:0
STABILITY_IMAGE_REGION=us-west-2
# Width/height used for Nova Canvas config; SD 3.5 uses aspect_ratio (project uses 1:1).
SCENE_IMAGE_WIDTH=1024
SCENE_IMAGE_HEIGHT=1024